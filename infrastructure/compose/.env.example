RABBITMQ_PASSWORD=stockup

# ===========================
# JWT
# ===========================
JWT_SECRET=replace-with-very-long-secret

# ===========================
# Firebase
# ===========================
FIREBASE_PROJECT_ID=

# ===========================
# Application
# ===========================
SPRING_PROFILES_ACTIVE=dev